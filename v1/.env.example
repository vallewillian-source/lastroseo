# LastroSEO V1 — Environment Variables
# Copy to .env and fill in the values you need.
# All services work WITHOUT Google/DeepSeek keys (fallback to SearXNG + Ollama).

# ── Google Ads API (optional) ─────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── DeepSeek API (optional, fallback LLM) ─────────────────────
DEEPSEEK_API_KEY=
