FROM golang:1.25-bookworm AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download 2>/dev/null || go mod tidy
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /storage-svc ./cmd/storage-svc/
FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /storage-svc /storage-svc
EXPOSE 8080
ENTRYPOINT ["/storage-svc"]
